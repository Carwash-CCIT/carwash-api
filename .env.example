# Server
PORT=3000
NODE_ENV=development

# CORS (comma-separated origins, use * for all)
ALLOWED_ORIGINS=*

# Gmail (for OTP email)
GMAIL_USER=your-email@gmail.com
GMAIL_PASS=your-app-password

# Thai Bulk SMS (for OTP SMS)
THAIBULKSMS_APP_KEY=your-api-key
THAIBULKSMS_APP_SECRET=your-api-secret

# SCB PromptPay
SCB_API_KEY=your-scb-api-key
SCB_API_SECRET=your-scb-api-secret
SCB_BILLER_ID=your-biller-id
SCB_MERCHANT_ID=your-merchant-id
SCB_SANDBOX=true

# Database (optional, for PostgreSQL migration in future)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=carwash
DB_USER=postgres
DB_PASSWORD=password
